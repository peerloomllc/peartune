<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTD/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- V8 JIT — required by Chromium's V8 engine in the renderer. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Required by sodium-native / rocksdb-native and other prebuilt native
       addons that map writable+executable memory at load time. -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Lets Electron pick up DYLD_LIBRARY_PATH overrides set by the runtime. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>

  <!-- Native P2P networking — HyperDHT bootstrap, phone connections, streaming. -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- Reading the music folder + a folder the operator picks in the dashboard. -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>

{
  "name": "peartune",
  "version": "0.1.0",
  "description": "Your self-hosted music, playable anywhere. P2P music player with no port forwarding, no VPN and no account.",
  "license": "MIT",
  "private": true,
  "main": "index.js",
  "bin": {
    "peartune-host": "./host/index.js"
  },
  "scripts": {
    "host": "node host/index.js",
    "test": "node --test test/*.test.js",
    "verify": "node --test test/*.test.js && npm run build:ui && npm run build:dashboard && npm run build:bare",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "build:bare": "bare-pack --linked --defer fs --defer path src/bare.js -o assets/bare-universal.bundle",
    "build:ui": "node scripts/build-ui.mjs",
    "build:dashboard": "node scripts/build-dashboard.mjs",
    "ios": "expo run:ios",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "b4a": "^1.6.7",
    "bare-fs": "^4.7.4",
    "bare-http1": "^4.5.7",
    "bare-path": "^3.1.1",
    "compact-encoding": "^2.16.0",
    "corestore": "^7.4.4",
    "expo": "^54.0.10",
    "expo-asset": "~12.0.9",
    "expo-audio": "^1.1.1",
    "expo-build-properties": "^1.0.9",
    "expo-clipboard": "~8.0.8",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.7",
    "expo-image-picker": "~17.0.11",
    "expo-network": "~8.0.8",
    "expo-router": "^6.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-system-ui": "^6.0.7",
    "hyperbee": "^2.24.2",
    "hypercore-crypto": "^3.6.1",
    "hyperdht": "^6.20.3",
    "hyperswarm": "^4.8.4",
    "jsqr": "^1.4.0",
    "music-metadata": "^11.14.0",
    "protomux": "^3.10.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-bare-kit": "^0.12.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0",
    "sodium-universal": "^5.0.1",
    "z32": "^1.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "bare": "^1.30.3",
    "bare-http1": "^4.5.7",
    "bare-pack": "^2.0.0",
    "esbuild": "^0.25.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  }
}

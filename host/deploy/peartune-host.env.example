# PearTune host configuration (systemd EnvironmentFile).
# Copy to /etc/peartune/peartune-host.env, edit, then:
#   systemctl enable --now peartune-host

# Where your music lives - a directory the `peartune` user can READ.
PEARTUNE_MUSIC=/srv/music

# Identity seed + grant store + the generated dashboard password. Must be WRITABLE
# by the `peartune` user, and must match ReadWritePaths in the .service. BACK THIS
# UP: losing it means every phone must re-pair.
PEARTUNE_DATA=/var/lib/peartune

# The library name a phone sees when it pairs.
PEARTUNE_NAME=My Library

# Dashboard bind. 0.0.0.0 exposes it to your LAN (needs a password - see below);
# 127.0.0.1 keeps it local, reachable only over an SSH tunnel.
PEARTUNE_HTTP_HOST=0.0.0.0
PEARTUNE_HTTP_PORT=8741

# Dashboard password. Leave this UNSET on a 0.0.0.0 bind and the host generates one
# on first run, prints it to the journal (journalctl -u peartune-host), and saves
# it to $PEARTUNE_DATA/dashboard-password. Set it here to choose your own.
#PEARTUNE_PASSWORD=

# Optional: serve an existing Subsonic/Navidrome (or Jellyfin/Emby) library instead
# of the folder above. Uncomment and fill in.
#PEARTUNE_NAVIDROME_URL=http://localhost:4533
#PEARTUNE_NAVIDROME_USER=you
#PEARTUNE_NAVIDROME_PASS=your-password
